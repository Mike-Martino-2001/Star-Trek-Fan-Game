<Window x:Class="StarTrekFanGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Star Trek Fan Game" Height="580" Width="940" WindowState="Maximized"
        Icon="Assets/Icons/startrek_logo_icon_48x48.ico"
        PreviewKeyDown="Window_KeyDown"
        PreviewKeyUp="Window_KeyUp"
        Deactivated="Window_Deactivated">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <!-- Game canvas. A fixed 960x540 "virtual" resolution drives all game
             logic; the Viewbox uniformly scales the whole scene to the window,
             so every entity grows/shrinks together with the window size. -->
        <Viewbox Grid.Row="0" Stretch="Uniform">
            <Canvas Name="ShapeCanvas"
                    Width="960" Height="540"
                    Background="Black"
                    Cursor="None"
                    SizeChanged="ShapeCanvas_SizeChanged"
                    Loaded="ShapeCanvas_Loaded"
                    MouseMove="ShapeCanvas_MouseMove"
                    MouseEnter="ShapeCanvas_MouseEnter"
                    MouseLeave="ShapeCanvas_MouseLeave"
                    MouseLeftButtonDown="ShapeCanvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="ShapeCanvas_MouseLeftButtonUp"
                    LostMouseCapture="ShapeCanvas_LostMouseCapture"/>
        </Viewbox>

        <!-- Control bar -->
        <WrapPanel Grid.Row="1"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="4 0">

            <!-- Spawn / Clear -->
            <Button Name="SpawnButton"  Width="80"  Height="30" Margin="3 0"
                    Click="SpawnButton_Click">Spawn</Button>
            <Button Name="ClearButton"  Width="58"  Height="30" Margin="3 0"
                    Click="ClearButton_Click">Clear</Button>

            <Separator Width="1" Height="26" Margin="6 0"/>

            <!-- Playback -->
            <Button Name="PlayButton"  Width="58"  Height="30" Margin="3 0"
                    Click="PlayButton_Click">&#x25BA; Play</Button>
            <Button Name="StepButton"  Width="46"  Height="30" Margin="3 0"
                    Click="StepButton_Click">Step</Button>
            <Button Name="StopButton"  Width="58"  Height="30" Margin="3 0"
                    Click="StopButton_Click">&#x25A0; Stop</Button>

            <Separator Width="1" Height="26" Margin="6 0"/>

            <!-- Fire mode -->
            <Button Name="RifleButton"      Width="64"  Height="30" Margin="3 0" FontWeight="Bold"
                    Click="RifleButton_Click">Rifle</Button>
            <Button Name="MachineGunButton" Width="82"  Height="30" Margin="3 0"
                    Click="MachineGunButton_Click">MachGun</Button>
            <Button Name="ShootButton"      Width="60"  Height="30" Margin="3 0"
                    Background="#CC2200" Foreground="White" FontWeight="Bold"
                    Click="ShootButton_Click">Fire!</Button>

            <Separator Width="1" Height="26" Margin="6 0"/>

            <!-- Score -->
            <TextBlock Name="ScoreText"
                       Text="Score: 0"
                       Foreground="DarkGreen"
                       FontSize="14" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="6 0"/>
		</WrapPanel>

		<!-- Pause overlay (ESC to open / close) -->
		<Grid x:Name="PauseOverlay" Grid.Row="0" Visibility="Collapsed" Panel.ZIndex="20">
			<Grid.Background>
				<SolidColorBrush Color="Black" Opacity="0.68"/>
			</Grid.Background>
			<Border HorizontalAlignment="Center" VerticalAlignment="Center"
					Background="#111827" BorderBrush="#00BFFF" BorderThickness="2"
					CornerRadius="6" Padding="40 30">
				<StackPanel Width="320">

					<!-- Title -->
					<TextBlock Text="&#x23F8;  PAUSED" FontSize="28" FontWeight="Bold"
							   Foreground="#00BFFF" HorizontalAlignment="Center"
							   Margin="0 0 0 26"/>

					<!-- Music Volume -->
					<TextBlock Text="MUSIC VOLUME" FontSize="11" FontWeight="Bold"
							   Foreground="#888888" Margin="0 0 0 4"/>
					<Grid Margin="0 0 0 18">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="44"/>
						</Grid.ColumnDefinitions>
						<Slider x:Name="MusicSlider" Grid.Column="0"
								Minimum="0" Maximum="100" Value="20"
								VerticalAlignment="Center"
								Foreground="#00BFFF"
								ValueChanged="MusicSlider_ValueChanged"/>
						<TextBlock x:Name="MusicPct" Grid.Column="1" Text="20%"
								   Foreground="White" FontSize="12"
								   VerticalAlignment="Center"
								   HorizontalAlignment="Right"/>
					</Grid>

					<!-- SFX Volume -->
					<TextBlock Text="SOUND EFFECTS" FontSize="11" FontWeight="Bold"
							   Foreground="#888888" Margin="0 0 0 4"/>
					<Grid Margin="0 0 0 28">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="44"/>
						</Grid.ColumnDefinitions>
						<Slider x:Name="SfxSlider" Grid.Column="0"
								Minimum="0" Maximum="100" Value="20"
								VerticalAlignment="Center"
								Foreground="#00BFFF"
								ValueChanged="SfxSlider_ValueChanged"/>
						<TextBlock x:Name="SfxPct" Grid.Column="1" Text="20%"
								   Foreground="White" FontSize="12"
								   VerticalAlignment="Center"
								   HorizontalAlignment="Right"/>
					</Grid>

					<!-- Resume -->
					<Button Content="&#x25BA;  RESUME" Width="150" Height="38"
							HorizontalAlignment="Center"
							Background="#0D2137" Foreground="#00BFFF"
							BorderBrush="#00BFFF" BorderThickness="1.5"
							FontSize="14" FontWeight="Bold"
							Click="ResumeButton_Click"/>
					<TextBlock Text="or press ESC" FontSize="10"
							   Foreground="#555555" HorizontalAlignment="Center"
							   Margin="0 7 0 0"/>

				</StackPanel>
			</Border>
		</Grid>

	</Grid>
</Window>
